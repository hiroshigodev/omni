{
  "rules": [
    {
      "name": "mask-passwords",
      "match": "password:",
      "action": "mask"
    }
  ],
  "dsl_filters": [
    {
      "name": "git-status-test",
      "trigger": "On branch",
      "rules": [
        { "capture": "On branch {branch}", "action": "keep" },
        { "capture": "modified: {file}", "action": "count", "as": "mod" }
      ],
      "output": "GIT_REPORT: branch={branch} total_modified={mod}"
    }
  ]
}
